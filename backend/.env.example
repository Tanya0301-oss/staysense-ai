# ── Groq Configuration ──────────────────────────────
# API key from https://console.groq.com/keys
GROQ_API_KEY=Here is my Groq Api key

# Model to use for Groq
# Current models: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ── Server Configuration ─────────────────────────────
# Port on which the Express server will listen
PORT=3000

# Environment: development or production
NODE_ENV=development

# ── Rate Limiting Configuration ──────────────────────
# Time window for rate limiting in milliseconds (1 minute = 60000)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests allowed per window
RATE_LIMIT_MAX_REQUESTS=30

# ── Batch Processing Configuration ───────────────────
# Maximum number of reviews allowed per API request (1-50)
MAX_REVIEWS_PER_REQUEST=50

# Number of concurrent LLM API calls for batch processing (1-10)
LLM_CONCURRENCY=5

# Timeout for individual LLM calls in milliseconds
LLM_TIMEOUT_MS=30000

# ── MongoDB Atlas ─────────────────────────────────────
# Connection string from MongoDB Atlas → Database → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your Atlas credentials
MONGODB_URI=Here is my MOngoDB url


# ── Frontend CORS ────────────────────────────────────
# Uncomment and configure if frontend is on a different origin
# CORS_ORIGIN=http://localhost:5173
